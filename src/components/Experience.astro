---
import { COMPANIES } from '../constants/Constants.ts';
---

<section class="w-full flex justify-center py-12 md:py-24 px-4 md:px-10" id="experience">
  <div class="layout-content-container flex flex-col max-w-240 flex-1">
    <div class="flex flex-col items-center gap-8 mb-10 text-center">
      <p class="text-sm font-bold text-primary uppercase tracking-widest">
        Previously worked with
      </p>
      <div
        class="grid grid-cols-2 md:grid-cols-4 gap-12 w-full max-w-4xl items-center justify-items-center"
      >
        {
          COMPANIES.map((company) => (
            <div class="flex flex-col items-center gap-4 cursor-default">
              <div class="flex items-center justify-center">
                <div
                  class="flex items-center justify-center rounded-full bg-white border border-blue-100 dark:bg-slate-400 dark:border-slate-700 px-8 py-4"
                  style="min-width:120px;min-height:56px"
                >
                  <img
                    src={company.icon}
                    alt={`${company.name} logo`}
                    width={company.width ?? 64}
                    height={company.height ?? 64}
                    loading="lazy"
                    decoding="async"
                    class="max-w-full max-h-full object-contain"
                  />
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

